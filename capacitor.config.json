{
  "appId": "com.freeradicals.drift",
  "appName": "DRIFT",
  "webDir": "preview",
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#0a0a0a",
    "preferredContentMode": "mobile"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true,
      "fadeInDuration": 0,
      "fadeOutDuration": 300
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0a",
      "overlaysWebView": true
    }
  }
}
